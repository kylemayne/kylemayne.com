---
import Nav from '../components/Nav.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Kyle Mayne: Principal Product Designer and Design Lead',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const site = Astro.site ?? new URL('https://kylemayne.com/');
const pageTitleFull = title === 'Kyle Mayne' ? title : `${title} - Kyle Mayne`;
const ogImageURL = new URL('/images/kyle.png', site);
const isHome = Astro.url.pathname === '/';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Kyle Mayne',
  url: site.href,
  image: ogImageURL.href,
  jobTitle: 'Principal Product Designer and Design Lead',
  sameAs: ['https://linkedin.com/in/kylemayne', 'https://twitter.com/kylemayne'],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover"
    />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <title>{pageTitleFull}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:site_name" content="Kyle Mayne" />
    <meta property="og:title" content={pageTitleFull} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL.href} />
    <meta property="og:image:width" content="1024" />
    <meta property="og:image:height" content="1024" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitleFull} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL.href} />
    <meta name="twitter:image:alt" content="Portrait of Kyle Mayne" />
    {
      isHome && (
        <>
          <link
            rel="preload"
            as="image"
            href="/images/kyle-dark.png"
            media="(prefers-color-scheme: dark)"
            fetchpriority="high"
          />
          <link
            rel="preload"
            as="image"
            href="/images/kyle.png"
            media="(prefers-color-scheme: light), (prefers-color-scheme: no-preference)"
            fetchpriority="high"
          />
        </>
      )
    }
    <script type="application/ld+json">
      {JSON.stringify(jsonLd)}
    </script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <div class="site-wrapper">
      <main id="main-content" class="site-content" tabindex="-1">
        <slot />
      </main>
      <Nav />
    </div>
  </body>
</html>
