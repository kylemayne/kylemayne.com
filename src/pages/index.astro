---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Kyle Mayne"
  description="Principal Product Designer and Design Lead. Work, expertise, and writing on product design, systems, and leadership."
>
  <div class="home-container">
    <div class="home-content">
      <div class="home-hero">
        <div class="home-hero-image">
          <picture>
            <source
              media="(prefers-color-scheme: dark)"
              srcset="/images/kyle-dark.png"
            />
            <img
              class="home-photo"
              src="/images/kyle.png"
              width="1024"
              height="1024"
              alt="Portrait of Kyle Mayne"
              loading="eager"
              fetchpriority="high"
              decoding="async"
            />
          </picture>
        </div>

        <div class="home-hero-text">
          <h1>Kyle Mayne</h1>

          <div class="prose">
            <p>
              I'm a Principal Product Designer and Design Lead with 15+ years
              shipping user-centered products across AI, FinTech, and Enterprise SaaS.
            </p>
            <p>
              I currently lead product design at <a href="https://www.sage.com/en-gb/" target="_blank" rel="noopener noreferrer">Sage<span class="sr-only"> (opens in new tab)</span></a>, shaping the end-to-end
              experience for cloud-based accounting and AI-powered tools used by
              millions of small businesses worldwide.
            </p>
            <p>
              Prior to Sage, I worked at the <a href="https://www.bbc.co.uk/" target="_blank" rel="noopener noreferrer">BBC<span class="sr-only"> (opens in new tab)</span></a> and <a href="https://www.instagram.com/orange_bus/" target="_blank" rel="noopener noreferrer">Orange Bus<span class="sr-only"> (opens in new tab)</span></a>.
            </p>
          </div>

          <div class="intro-links">
            <a href="https://linkedin.com/in/kylemayne" target="_blank" rel="noopener noreferrer">
              LinkedIn<span class="sr-only"> (opens in new tab)</span>
            </a>
            <a href="https://twitter.com/kylemayne" target="_blank" rel="noopener noreferrer">
              Twitter<span class="sr-only"> (opens in new tab)</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
