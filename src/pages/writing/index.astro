---
import Layout from '../../layouts/Layout.astro';
import { writingGroupedByYear } from '../../data/writing';

const groups = await writingGroupedByYear();
---

<Layout
  title="Writing"
  description="Writing by Kyle Mayne on design, product, and leadership."
  ogImage="/og/writing-index.png"
  ogImageWidth={1200}
  ogImageHeight={630}
  twitterCard="summary_large_image"
>
  <div class="writing-header">
    <h1>Writing</h1>
    <p class="writing-rss">
      <a href="/rss.xml">
        <svg
          class="writing-rss-icon"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          width="16"
          height="16"
          aria-hidden="true"
          focusable="false"
        >
          <circle cx="5" cy="19" r="2" fill="currentColor" />
          <path
            d="M4 11a9 9 0 0 1 9 9"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
          />
          <path
            d="M4 4a16 16 0 0 1 16 16"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
          />
        </svg>
        RSS feed
      </a>
    </p>
  </div>

  <div class="page-section">
    {
      groups.length === 0 ? (
        <p class="writing-empty">Coming soon.</p>
      ) : (
        groups.map(({ year, articles }) => (
          <section class="writing-year" aria-labelledby={`writing-year-${year}`}>
            <h2 class="writing-year-heading" id={`writing-year-${year}`}>
              {year}
            </h2>
            <ul class="writing-list">
              {articles.map((article) => (
                <li>
                  <a class="writing-list-link" href={`/writing/${article.slug}/`}>
                    <span class="writing-list-title">{article.data.title}</span>
                    {article.data.description ? (
                      <span class="writing-list-desc">{article.data.description}</span>
                    ) : null}
                  </a>
                </li>
              ))}
            </ul>
          </section>
        ))
      )
    }
  </div>
</Layout>
