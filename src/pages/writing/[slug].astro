---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { getArticle, getNextArticleSlug } from '../../data/writing';

export async function getStaticPaths() {
  const articles = await getCollection('writing');
  return articles.map((article) => ({
    params: { slug: article.slug },
  }));
}

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/writing/');
}

const article = await getArticle(slug);

if (!article) {
  return Astro.redirect('/writing/');
}

const nextSlug = await getNextArticleSlug(slug);
const description =
  article.data.description ?? article.body.slice(0, 160) ?? '';

const pubDate = article.data.pubDate;
const pubDateLabel = new Intl.DateTimeFormat('en-GB', {
  month: 'long',
  year: 'numeric',
}).format(pubDate);
const pubDateISO = pubDate.toLocaleDateString('en-CA');
const articlePublishedTime = pubDate.toISOString();

const site = Astro.site ?? new URL('https://kylemayne.com/');
const articleUrl = new URL(`/writing/${slug}/`, site);

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: article.data.title,
  description,
  datePublished: articlePublishedTime,
  author: {
    '@type': 'Person',
    name: 'Kyle Mayne',
    url: site.href,
  },
  publisher: {
    '@type': 'Person',
    name: 'Kyle Mayne',
  },
  image: new URL('/images/kyle.png', site).href,
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': articleUrl.href,
  },
};

const { Content } = await article.render();
---

<Layout
  title={article.data.title}
  description={description}
  bodyClass="page-article"
  ogType="article"
  articlePublishedTime={articlePublishedTime}
  structuredData={articleJsonLd}
>
  <article class="article">
    <header class="article-header">
      <h1 class="article-title">{article.data.title}</h1>
      <p class="article-meta">
        <time datetime={pubDateISO}>{pubDateLabel}</time>
      </p>
    </header>

    <div class="article-body prose">
      <Content />
    </div>

    <nav class="article-footer-nav" aria-label="Article">
      <a class="article-nav-link article-nav-prev" href="/writing/">
        ← All articles
      </a>
      {
        nextSlug && (
          <a class="article-nav-link article-nav-next" href={`/writing/${nextSlug}/`}>
            Next article →
          </a>
        )
      }
    </nav>
  </article>
</Layout>
